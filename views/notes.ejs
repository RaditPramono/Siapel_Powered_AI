<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Catatan - SIAPEL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <style>
        * { font-family: 'Poppins', sans-serif; }
        body { background: #F5F5F5; margin: 0; padding: 0; transition: background 0.3s ease; }
        .bg-telkom { background-color: #DC0000; }
        .sidebar { background: white; border-right: 1px solid #ddd; transition: all 0.3s ease; }
        .nav-item:hover { background-color: #FFF5F5; color: #DC0000; }
        .note-card { background: white; border-radius: 16px; border: 1px solid #ddd; transition: all 0.3s ease; }
        .note-card:hover { transform: translateY(-3px); box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); }
        
        body.dark { background-color: #0f172a !important; color: #f1f5f9 !important; }
        body.dark .sidebar { background-color: #1e293b !important; border-right-color: #334155 !important; }
        body.dark .sidebar .text-gray-800, body.dark .sidebar .text-gray-700, body.dark .sidebar h1, body.dark .sidebar p { color: #f1f5f9 !important; }
        body.dark .nav-item { color: #cbd5e1 !important; }
        body.dark .nav-item:hover { background-color: #334155 !important; color: #ffffff !important; }
        body.dark .note-card { background-color: #1e293b !important; border-color: #334155 !important; color: #f1f5f9 !important; }
        body.dark .text-gray-800, body.dark .text-gray-700, body.dark .font-bold { color: #f1f5f9 !important; }
        body.dark .text-gray-400, body.dark .text-gray-500 { color: #94a3b8 !important; }
        body.dark .bg-gray-50, body.dark .bg-gray-100, body.dark .bg-white { background-color: #1e293b !important; }
        body.dark .border-gray-100, body.dark .border-gray-200 { border-color: #334155 !important; }
        body.dark .menu-btn { background-color: #DC0000 !important; }
        
        .menu-btn { position: fixed; top: 12px; left: 12px; z-index: 999; background: #DC0000; color: white; padding: 10px 14px; border-radius: 12px; display: none; cursor: pointer; }
        @media (max-width: 768px) { 
            .menu-btn { display: block; } 
            .sidebar { position: fixed; top: 0; left: 0; height: 100vh; z-index: 1000; width: 280px; transform: translateX(-100%); transition: transform 0.3s ease; overflow-y: auto; } 
            .sidebar.open { transform: translateX(0); } 
            .main-content { padding-top: 60px; } 
            .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 998; } 
            .sidebar-overlay.active { display: block; } 
        }
    </style>
</head>
<body>
    <button onclick="toggleSidebar()" class="menu-btn"><i class="fas fa-bars text-xl"></i></button>
    <div id="sidebarOverlay" class="sidebar-overlay" onclick="toggleSidebar()"></div>
    
    <div class="flex h-screen">
        <%- include('partials/sidebar.ejs') %>
        
        <main class="flex-1 overflow-y-auto p-4 md:p-8 main-content">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 md:mb-8">
                <div><h1 class="text-2xl md:text-3xl font-bold text-gray-800"><i class="fas fa-book text-telkom mr-3"></i>Catatan Belajar</h1><p class="text-xs md:text-sm text-gray-400 mt-1">Simpan materi pelajaranmu di sini</p></div>
                <button onclick="openAddModal()" class="bg-telkom text-white px-4 md:px-6 py-2 md:py-3 rounded-xl font-bold text-sm md:text-base w-full sm:w-auto"><i class="fas fa-plus mr-2"></i>Catatan Baru</button>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                <% notes.forEach(function(note) { %>
                    <div class="note-card p-4 md:p-5">
                        <div class="flex justify-between items-start">
                            <div class="flex-1 min-w-0"><h3 class="text-base md:text-lg font-bold text-gray-800 truncate"><%= note.title %></h3><p class="text-xs text-gray-400 mt-1 truncate"><%= note.subject || 'Tanpa Mapel' %></p><p class="text-gray-600 mt-3 text-xs md:text-sm break-words"><%= note.content.substring(0, 100) %>...</p></div>
                            <div class="flex gap-2 ml-2"><button data-note-id="<%= note.id %>" onclick="generateQuiz(this.dataset.noteId)" class="px-2 md:px-3 py-1 bg-blue-500 text-white rounded-lg text-xs md:text-sm font-bold whitespace-nowrap"><i class="fas fa-magic mr-1"></i>Quiz</button><form action="/notes/delete/<%= note.id %>" method="POST" onsubmit="return confirm('Yakin hapus catatan ini?')"><button type="submit" class="px-2 md:px-3 py-1 bg-red-500 text-white rounded-lg text-xs md:text-sm"><i class="fas fa-trash"></i></button></form></div>
                        </div>
                        <div id="quiz-result-<%= note.id %>" class="mt-3 text-xs"></div>
                    </div>
                <% }); %>
                <% if (notes.length === 0) { %><div class="col-span-2 bg-white rounded-2xl p-8 md:p-12 text-center note-card"><i class="fas fa-book-open text-4xl md:text-5xl text-gray-300 mb-4"></i><p class="text-gray-400 text-sm md:text-base">Belum ada catatan. Buat catatan pertama kamu!</p></div><% } %>
            </div>
        </main>
    </div>
    
    <div id="addModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4">
        <div class="bg-white rounded-2xl p-6 w-full max-w-md max-h-[90vh] overflow-y-auto">
            <h2 class="text-xl font-bold mb-4"><i class="fas fa-plus-circle text-telkom mr-2"></i>Tambah Catatan</h2>
            <form action="/notes/add" method="POST">
                <input type="text" name="title" placeholder="Judul" class="w-full p-3 border rounded-xl mb-3" required>
                <textarea name="content" placeholder="Isi catatan" class="w-full p-3 border rounded-xl mb-3" rows="5" required></textarea>
                <input type="text" name="subject" placeholder="Mata Pelajaran" class="w-full p-3 border rounded-xl mb-4">
                <div class="flex justify-end space-x-3">
                    <button type="button" onclick="closeAddModal()" class="px-4 py-2 bg-gray-300 rounded-xl">Batal</button>
                    <button type="submit" class="px-4 py-2 bg-telkom text-white rounded-xl">Simpan</button>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        function openAddModal() { document.getElementById('addModal').classList.remove('hidden'); document.getElementById('addModal').classList.add('flex'); }
        function closeAddModal() { document.getElementById('addModal').classList.remove('flex'); document.getElementById('addModal').classList.add('hidden'); }
        
        // ========== GENERATE QUIZ (10 SOAL) DENGAN AUTO REFRESH ==========
        async function generateQuiz(noteId) { 
            let resultDiv = document.getElementById(`quiz-result-${noteId}`); 
            resultDiv.innerHTML = '<i class="fas fa-spinner fa-spin"></i> AI sedang membuat 10 soal...'; 
            try {
                let res = await fetch(`/notes/generate-quiz/${noteId}`, { method: 'POST' }); 
                let data = await res.json(); 
                if (data.success) { 
                    resultDiv.innerHTML = `<i class="fas fa-check-circle text-green-600"></i> ✅ Berhasil generate ${data.count} soal! <a href="/quiz" class="text-telkom underline font-bold">Kerjakan quiz →</a>`; 
                    // Auto refresh setelah 1.5 detik biar quiz langsung muncul di halaman quiz
                    setTimeout(() => { window.location.href = '/quiz'; }, 1500);
                } else { 
                    resultDiv.innerHTML = '<i class="fas fa-exclamation-circle text-red-600"></i> ❌ Gagal generate quiz. Coba lagi.'; 
                }
            } catch (err) {
                resultDiv.innerHTML = '<i class="fas fa-exclamation-circle text-red-600"></i> ❌ Error koneksi. Coba lagi.';
            }
        }
        
        function toggleDarkMode() { document.body.classList.toggle('dark'); localStorage.setItem('darkMode', document.body.classList.contains('dark') ? 'enabled' : 'disabled'); }
        if (localStorage.getItem('darkMode') === 'enabled') { document.body.classList.add('dark'); }
        
        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('open'); document.getElementById('sidebarOverlay').classList.toggle('active'); }
        if (window.innerWidth < 768) { document.querySelectorAll('#sidebar a').forEach(link => { link.addEventListener('click', () => { if (window.innerWidth < 768) toggleSidebar(); }); }); }
    </script>
</body>
</html>