<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hasil Quiz - SIAPEL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <style>
        * { font-family: 'Poppins', sans-serif; }
        body { background: #F5F5F5; }
        .bg-telkom { background-color: #DC0000; }
    </style>
</head>
<body class="flex items-center justify-center min-h-screen p-6">
    <div class="bg-white rounded-2xl p-8 text-center max-w-md w-full shadow-lg">
        <div class="mb-4">
            <% if (percentage >= 80) { %>
                <i class="fas fa-trophy text-5xl text-yellow-500 mb-3"></i>
            <% } else if (percentage >= 60) { %>
                <i class="fas fa-smile-wink text-5xl text-green-500 mb-3"></i>
            <% } else { %>
                <i class="fas fa-book-open text-5xl text-gray-400 mb-3"></i>
            <% } %>
        </div>
        <h1 class="text-2xl font-bold text-gray-800 mb-2">📊 Hasil Quiz</h1>
        <p class="text-gray-500 mb-4"><%= noteTitle %></p>
        <div class="text-5xl font-bold text-telkom mb-3"><%= score %>/<%= total %></div>
        <div class="w-full bg-gray-200 rounded-full h-3 mb-4">
            <div class="bg-telkom h-3 rounded-full" data-pct="<%= percentage %>" id="scoreBar"></div>
        </div>
        <p class="text-gray-600 mb-6">Nilai: <strong><%= percentage %>%</strong></p>
        
        <% if (percentage >= 80) { %>
            <p class="text-green-600 mb-6">🎉 Selamat! Kamu hebat!</p>
        <% } else if (percentage >= 60) { %>
            <p class="text-yellow-600 mb-6">👍 Cukup baik, tingkatkan lagi!</p>
        <% } else { %>
            <p class="text-red-600 mb-6">📚 Belajar lagi ya, semangat!</p>
        <% } %>
        
        <a href="/quiz" class="bg-telkom text-white px-6 py-2 rounded-xl inline-block hover:bg-red-700 transition">Kembali ke Daftar Quiz</a>
    </div>
    <script>
        var bar = document.getElementById('scoreBar');
        if (bar) bar.style.width = bar.getAttribute('data-pct') + '%';
    </script>
</body>
</html>