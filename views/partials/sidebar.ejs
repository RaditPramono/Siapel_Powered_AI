<script>
    var currentPath = window.location.pathname;
    var activeId = '';
    if (currentPath === '/dashboard') activeId = 'nav-dashboard';
    else if (currentPath === '/tasks') activeId = 'nav-tasks';
    else if (currentPath === '/notes') activeId = 'nav-notes';
    else if (currentPath === '/quiz') activeId = 'nav-quiz';
    else if (currentPath === '/schedule') activeId = 'nav-schedule';
    else if (currentPath === '/study') activeId = 'nav-study';
    else if (currentPath === '/gamification') activeId = 'nav-gamification';
    else if (currentPath === '/flashcard') activeId = 'nav-flashcard';
    else if (currentPath === '/ai-chat') activeId = 'nav-ai-chat';
    
    if (activeId) {
        var activeLink = document.getElementById(activeId);
        if (activeLink) {
            activeLink.classList.add('bg-telkom', 'text-white');
            activeLink.classList.remove('text-gray-700', 'hover:bg-gray-100');
        }
    }
    
    function toggleDarkMode() { 
        document.body.classList.toggle('dark'); 
        localStorage.setItem('darkMode', document.body.classList.contains('dark') ? 'enabled' : 'disabled');
    }
    if (localStorage.getItem('darkMode') === 'enabled') { document.body.classList.add('dark'); }
</script>