<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Kerjakan Quiz - SIAPEL</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">
    <style>
        * { font-family: 'Poppins', sans-serif; }
        body { background: #F5F5F5; margin: 0; padding: 0; transition: background 0.3s ease; }
        .bg-telkom { background-color: #DC0000; }
        .quiz-card { background: white; border-radius: 16px; border: 1px solid #ddd; transition: all 0.3s ease; }
        .progress-bar { height: 8px; background: #e5e7eb; border-radius: 4px; }
        .progress-fill { height: 8px; background: #DC0000; border-radius: 4px; transition: width 0.3s ease; }
        
        body.dark { background-color: #0f172a !important; color: #f1f5f9 !important; }
        body.dark .quiz-card { background-color: #1e293b !important; border-color: #334155 !important; color: #f1f5f9 !important; }
        body.dark .text-gray-800, body.dark .text-gray-700, body.dark .font-bold, body.dark .text-gray-600 { color: #f1f5f9 !important; }
        body.dark .text-gray-400, body.dark .text-gray-500 { color: #94a3b8 !important; }
        body.dark .bg-gray-50 { background-color: #0f172a !important; }
        body.dark .border-gray-200 { border-color: #334155 !important; }
        body.dark .menu-btn { background-color: #DC0000 !important; }
        
        .menu-btn { position: fixed; top: 12px; left: 12px; z-index: 999; background: #DC0000; color: white; padding: 10px 14px; border-radius: 12px; display: none; cursor: pointer; }
        @media (max-width: 768px) { .menu-btn { display: block; } }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-8">
    <button onclick="toggleSidebar()" class="menu-btn"><i class="fas fa-bars text-xl"></i></button>
    <div class="quiz-card p-8 w-full max-w-2xl">
        <div class="mb-6">
            <a href="/quiz" class="text-telkom hover:underline text-sm"><i class="fas fa-arrow-left mr-1"></i>Kembali</a>
        </div>
        
        <h1 class="text-2xl font-bold text-gray-800 mb-2">📝 <%= noteTitle %></h1>
        <p class="text-sm text-gray-500 mb-6">Kerjakan <strong><%= total %></strong> soal berikut</p>
        
        <!-- Progress Bar -->
        <div class="mb-6">
            <div class="flex justify-between text-sm text-gray-500 mb-1">
                <span>Soal <span id="currentNum">1</span> dari <span id="totalNum"><%= total %></span></span>
                <span id="percent">0%</span>
            </div>
            <div class="progress-bar"><div id="progressFill" class="progress-fill" style="width: 0%"></div></div>
        </div>
        
        <form id="quizForm" action="/quiz/submit-all" method="POST">
            <input type="hidden" name="note_id" value="<%= noteId %>">
            <input type="hidden" name="total" value="<%= total %>">
            
            <div id="questionsContainer">
                <% questions.forEach((q, idx) => { %>
                    <div class="question-item" data-index="<%= idx %>" style="display:none">
                        <p class="font-semibold text-gray-800 mb-4 text-lg"><%= idx+1 %>. <%= q.question %></p>
                        <div class="space-y-3 mb-8">
                            <label class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 cursor-pointer transition-all">
                                <input type="radio" name="answer_<%= q.id %>" value="A" class="w-4 h-4 text-telkom"> 
                                <span class="text-gray-700">A. <%= q.option_a %></span>
                            </label>
                            <label class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 cursor-pointer transition-all">
                                <input type="radio" name="answer_<%= q.id %>" value="B" class="w-4 h-4 text-telkom"> 
                                <span class="text-gray-700">B. <%= q.option_b %></span>
                            </label>
                            <label class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 cursor-pointer transition-all">
                                <input type="radio" name="answer_<%= q.id %>" value="C" class="w-4 h-4 text-telkom"> 
                                <span class="text-gray-700">C. <%= q.option_c %></span>
                            </label>
                            <label class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 cursor-pointer transition-all">
                                <input type="radio" name="answer_<%= q.id %>" value="D" class="w-4 h-4 text-telkom"> 
                                <span class="text-gray-700">D. <%= q.option_d %></span>
                            </label>
                        </div>
                    </div>
                <% }); %>
            </div>
            
            <div class="flex justify-between gap-3 mt-4">
                <button type="button" id="prevBtn" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-6 py-2 rounded-xl font-semibold transition-all" disabled>
                    <i class="fas fa-chevron-left mr-1"></i> Sebelum
                </button>
                <button type="button" id="nextBtn" class="bg-telkom hover:bg-red-700 text-white px-6 py-2 rounded-xl font-semibold transition-all">
                    Selanjutnya <i class="fas fa-chevron-right ml-1"></i>
                </button>
                <button type="submit" id="submitBtn" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-xl font-semibold transition-all" style="display: none;">
                    <i class="fas fa-check-circle mr-1"></i> Submit Semua
                </button>
            </div>
        </form>
    </div>
    
    <!-- Data quiz -->
    <span id="quizData" data-total="<%= total %>" style="display:none"></span>

    <script>
        const total = parseInt(document.getElementById('quizData').getAttribute('data-total'), 10);
        let current = 0;
        const questions = document.querySelectorAll('.question-item');
        const prevBtn = document.getElementById('prevBtn');
        const nextBtn = document.getElementById('nextBtn');
        const submitBtn = document.getElementById('submitBtn');
        const currentNum = document.getElementById('currentNum');
        const progressFill = document.getElementById('progressFill');
        const percentSpan = document.getElementById('percent');
        
        function updateUI() {
            questions.forEach((q, i) => {
                q.style.display = i === current ? 'block' : 'none';
            });
            currentNum.innerText = current + 1;
            const percent = ((current + 1) / total) * 100;
            progressFill.style.width = percent + '%';
            percentSpan.innerText = Math.round(percent) + '%';
            prevBtn.disabled = current === 0;
            
            if (current === total - 1) {
                nextBtn.style.display = 'none';
                submitBtn.style.display = 'inline-flex';
            } else {
                nextBtn.style.display = 'inline-flex';
                submitBtn.style.display = 'none';
            }
        }
        
        function nextQuestion() {
            if (current < total - 1) {
                current++;
                updateUI();
            }
        }
        
        function prevQuestion() {
            if (current > 0) {
                current--;
                updateUI();
            }
        }
        
        prevBtn.onclick = prevQuestion;
        nextBtn.onclick = nextQuestion;
        
        // Optional: Simpan jawaban sementara di localStorage (biar gak ilang pas bolak-balik)
        const inputs = document.querySelectorAll('input[type="radio"]');
        inputs.forEach(input => {
            input.addEventListener('change', () => {
                const name = input.getAttribute('name');
                const value = input.value;
                localStorage.setItem(name, value);
            });
            
            // Restore jawaban dari localStorage
            const name = input.getAttribute('name');
            const saved = localStorage.getItem(name);
            if (saved && saved === input.value) {
                input.checked = true;
            }
        });
        
        updateUI();
        
        function toggleDarkMode() { 
            document.body.classList.toggle('dark'); 
            localStorage.setItem('darkMode', document.body.classList.contains('dark') ? 'enabled' : 'disabled');
        }
        if (localStorage.getItem('darkMode') === 'enabled') { document.body.classList.add('dark'); }
        
        function toggleSidebar() { 
            window.location.href = '/quiz';
        }
    </script>
</body>
</html>